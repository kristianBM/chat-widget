{
  "name": "chat-widget",
  "version": "1.0.0",
  "description": "Production-quality embeddable chat widget built with Preact + Vite",
  "type": "module",
  "main": "./dist/chat-widget.umd.js",
  "module": "./dist/chat-widget.es.js",
  "exports": {
    ".": {
