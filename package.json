  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview"
  },
  "devDependencies": {
    "@preact/preset-vite": "^2.8.1",
    "vite": "^5.2.0"
  },
  "dependencies": {
    "preact": "^10.20.1"
  }
}
